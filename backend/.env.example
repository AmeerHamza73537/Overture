# ---------------------------------------------------------------------------
# Outreach backend environment variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# Server
PORT=3000
# Comma-separated list of allowed origins for CORS. Use * only for local dev.
CORS_ORIGIN=*

# --- Groq (LLM that parses natural-language queries into filters) ----------
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
# Model used for parsing. Llama 3.3 70B is a good default.
GROQ_MODEL=llama-3.3-70b-versatile

# --- Hunter.io (lead data provider) -----------------------------------------
# Get a key at https://hunter.io/api-keys
HUNTER_API_KEY=your_hunter_api_key_here
# People searches fan out: 1 Discover call + N Domain Search calls per page.
# These bound the fan-out so one request can't burn through the Hunter quota.
# Companies fetched (and Domain-Searched) per page of a people search:
HUNTER_COMPANIES_PER_PAGE=5
# Max contacts pulled per company (Hunter caps at 100; 10 is the plan default):
HUNTER_EMAILS_PER_COMPANY=10

# --- Gmail sending (Google OAuth) -------------------------------------------
# Follow backend/README.md "Gmail setup" to create these at
# https://console.cloud.google.com (OAuth client, Gmail API enabled).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must exactly match an Authorized redirect URI on the OAuth client.
# Default (when left blank): http://localhost:<PORT>/api/gmail/callback
GOOGLE_REDIRECT_URI=
# 64 hex chars encrypting the stored refresh token. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=
# Pause between sends in a batch (ms) and max emails per send request.
SEND_DELAY_MS=7000
SEND_MAX_BATCH=20

# --- Supabase (cache + search history) -------------------------------------
# Project URL, e.g. https://xxxxxxxxxxxx.supabase.co
# Leave BOTH blank to run with an in-memory cache and NO history persistence.
SUPABASE_URL=
# Server-side secret key (sb_secret_...). The legacy name
# SUPABASE_SERVICE_ROLE_KEY is also accepted. NEVER ship this to the app.
SUPABASE_SECRET_KEY=
# Public ("publishable"/anon) key (sb_publishable_...). Optional — used only
# for the auth client's user-facing calls; falls back to the secret key.
SUPABASE_PUBLISHABLE_KEY=

# --- App authentication (Supabase Auth) --------------------------------------
# Auth (sign up / sign in / password reset) turns on automatically when
# Supabase is configured above. Without Supabase, the API runs open, as the
# shared 'default' user (dev only).
#
# Where the password-reset email link lands after Supabase verifies it. The
# app normally sends its own deep link per request, so this is just the
# fallback. Whatever is used MUST be allowlisted in the Supabase dashboard:
# Auth -> URL Configuration -> Redirect URLs.
AUTH_RESET_REDIRECT_URL=overture://reset-password

# --- Caching / rate limiting -----------------------------------------------
# How long (seconds) to cache parse + search results. 1 day default.
CACHE_TTL_SECONDS=86400
# Rate limit window (ms) and max requests per window, per IP.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# --- Upstream request timeout (ms) -----------------------------------------
REQUEST_TIMEOUT_MS=20000
